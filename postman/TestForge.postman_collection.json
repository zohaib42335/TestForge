{
  "info": {
    "_postman_id": "b3e0e8c8-45a4-4f3a-a7b0-2dcf1ea4c441",
    "name": "TestForge API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for TestForge backend APIs."

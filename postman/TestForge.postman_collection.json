    {
      "name": "Smoke RBAC Assertions",
      "item": [
        {
          "name": "Admin Create Project => 200/201",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Admin can create project', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});"
                ]
              }
            }
